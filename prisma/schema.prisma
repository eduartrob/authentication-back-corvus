// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // 'ALUMNO', 'PROFESOR', 'ADMINISTRADOR'
  users User[]

  @@map("roles")
}

model User {
  id              String  @id @default(uuid()) @db.Uuid
  email           String  @unique
  secondary_email String? @unique
  username        String? @unique // Principalmente para ADMIN
  password_hash   String
  full_name       String? // Para ALUMNO y PROFESOR
  enrollment_id   String? @unique // Matrícula
  profile_picture String? // Para ALUMNO y PROFESOR
  roleId          Int
  role            Role    @relation(fields: [roleId], references: [id])

  universityId String?     @db.Uuid
  university   University? @relation(fields: [universityId], references: [id])

  careerId String? @db.Uuid
  career   Career? @relation(fields: [careerId], references: [id])

  semester String? @db.VarChar(255)
  cluster_id Int?

  user_skills UserSkill[]

  google_refresh_token String? @db.Text
  google_access_token  String? @db.Text

  linked_folders LinkedFolder[]
  llm_sessions   LlmSession[]
  activity_logs  ActivityLog[]

  // Campos de clustering
  team_id                 String?   @db.Uuid
  bio                     String?   @default("")
  tags                    String[]  @default([])
  is_verified             Boolean   @default(false)
  verification_code       String?
  verification_expires_at DateTime?
  google_email            String?
  secondary_is_verified   Boolean   @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model University {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @unique
  acronym          String?
  registrationCode String?  @unique

  users              User[]
  university_careers UniversityCareer[]

  @@map("universities")
}

model Career {
  id              String @id @default(uuid()) @db.Uuid
  name            String @unique
  normalized_name String @unique // For efficient similarity search

  users              User[]
  career_skills      CareerSkill[]
  university_careers UniversityCareer[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("careers")
}

model UniversityCareer {
  universityId String @db.Uuid
  careerId     String @db.Uuid

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  career     Career     @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@id([universityId, careerId])
  @@map("university_careers")
}

model Skill {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  career_skills CareerSkill[]
  user_skills   UserSkill[]

  @@map("skills")
}

model CareerSkill {
  careerId String @db.Uuid
  skillId  String @db.Uuid

  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([careerId, skillId])
  @@map("career_skills")
}

model UserSkill {
  userId  String @db.Uuid
  skillId String @db.Uuid

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model LinkedFolder {
  id          String @id @default(uuid()) @db.Uuid
  folder_id   String @unique
  folder_name String
  userId      String @db.Uuid
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("linked_folders")
}

model LlmSession {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos del análisis que originó la sesión
  proposal_title String?
  verdict        String // 'approved' | 'rejected'
  analysis_json  Json // Snapshot completo del JSON de analyze-proposal

  // Historial de mensajes de la conversación
  messages Json @default("[]") // [{role, content, timestamp}]

  // Control de cuota freemium
  session_number Int     @default(1) // Número de sesión del usuario (1, 2, 3...)
  is_active      Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("llm_sessions")
}

model ActivityLog {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String // 'LOGIN', 'UPLOAD_DOCUMENT', 'VALIDATE_CLUSTER', 'SYSTEM_ALERT'
  detail    String  @db.Text
  ipAddress String? @db.VarChar(45) // Support IPv6

  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
