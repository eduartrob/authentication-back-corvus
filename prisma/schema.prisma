// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // 'ALUMNO', 'PROFESOR', 'ADMINISTRADOR'
  users User[]
  
  @@map("roles")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  username        String?  @unique // Principalmente para ADMIN
  password_hash   String
  full_name       String?  // Para ALUMNO y PROFESOR
  profile_picture String?  // Para ALUMNO y PROFESOR
  roleId          Int
  role            Role     @relation(fields: [roleId], references: [id])
  
  google_refresh_token String? @db.Text
  google_access_token  String? @db.Text

  linked_folders  LinkedFolder[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model LinkedFolder {
  id          String   @id @default(uuid()) @db.Uuid
  folder_id   String   @unique
  folder_name String
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("linked_folders")
}
